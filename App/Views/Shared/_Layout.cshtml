<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - App</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/App.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="container" style=" ">
            <div style="font-size:20px; display: flex; justify-content:center;gap: 50px; margin:50px 0px;">
                    @if (User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Patient"))
                            {
                                <a asp-controller="PatientDashboard" asp-action="Index">Dashboard</a>
                                <a asp-controller="PatientDashboard" asp-action="MyAppointments">My Appointments</a>
                                <a asp-controller="PatientDashboard" asp-action="BookAppointment">Book Appointment</a>
                                <span>@ViewBag.PatientName!</span>
                            }
                            else if (User.IsInRole("Doctor"))
                            {
                                <a asp-controller="DoctorDashboard" asp-action="Index">Dashboard</a>
                                <a asp-controller="DoctorDashboard" asp-action="MyAppointments">My Appointments</a>
                                <a asp-controller="DoctorDashboard" asp-action="TodayAppointments">Today's Schedule</a>
                                <span>@ViewBag.DoctorName!</span>
                            }
                            else if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="AdminDashboard" asp-action="Users">Dashboard</a>
                                <span>@ViewBag.AdminName!</span>
                            }
                        <form asp-controller="Account" asp-action="Logout" method="post" style="display: inline;">
                            <button style="font-size:20px; padding: 2px 4px; color:white; background:green;" type="submit">Logout</button>
                        </form>
                    }
                    else
                    {
                        <div style="justify-content:center; display: flex; gap: 10px;">
                            <a asp-controller="Account" asp-action="Login">Login</a>
                            <a asp-controller="Account" asp-action="Register">Register</a>
                        </div>
                    }
                </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - App - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
