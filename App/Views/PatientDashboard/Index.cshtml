@{
    ViewData["Title"] = "Patient Dashboard";
    Layout = "_Layout";
}

<div style="padding: 20px;">
    <h1>Welcome, @ViewBag.PatientName!</h1>
    <p>Your health is our priority. Manage your appointments easily.</p>
    
    <hr />
    
    <div style="display: flex; gap: 20px; margin-top: 30px; flex-wrap: wrap;">
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 5px; width: 250px; text-align: center;">
            <h3>My Appointments</h3>
            <p>View all your scheduled appointments</p>
            <a asp-action="MyAppointments" style="display: inline-block; margin-top: 10px; padding: 8px 15px; background: #007bff; color: white; text-decoration: none; border-radius: 4px;">View Appointments</a>
        </div>
        
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 5px; width: 250px; text-align: center;">
            <h3>Book Appointment</h3>
            <p>Schedule a new appointment with a doctor</p>
            <a asp-action="BookAppointment" style="display: inline-block; margin-top: 10px; padding: 8px 15px; background: #28a745; color: white; text-decoration: none; border-radius: 4px;">Book Now</a>
        </div>
        
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 5px; width: 250px; text-align: center;">
            <h3>My Profile</h3>
            <p>View and update your profile information</p>
            <a asp-controller="Patient" asp-action="Edit" asp-route-id="@User.Identity.Name" style="display: inline-block; margin-top: 10px; padding: 8px 15px; background: #17a2b8; color: white; text-decoration: none; border-radius: 4px;">View Profile</a>
        </div>
    </div>
</div>
