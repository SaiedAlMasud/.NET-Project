@{
    ViewData["Title"] = "Doctor Dashboard";
    Layout = "_Layout";
}

<div style="padding: 20px;">
    <h1>Welcome, @ViewBag.DoctorName!</h1>
    <p>Manage your appointments and schedule efficiently.</p>
    
    <hr />
    
    <div style="display: flex; gap: 20px; margin-top: 30px; flex-wrap: wrap;">
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 5px; width: 250px; text-align: center;">
            <h2>📋</h2>
            <h3>All Appointments</h3>
            <p>View all your scheduled appointments</p>
            <a asp-action="MyAppointments" style="display: inline-block; margin-top: 10px; padding: 8px 15px; background: #007bff; color: white; text-decoration: none; border-radius: 4px;">View All</a>
        </div>
        
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 5px; width: 250px; text-align: center;">
            <h2>📅</h2>
            <h3>Today's Appointments</h3>
            <p>View today's schedule</p>
            <a asp-action="TodayAppointments" style="display: inline-block; margin-top: 10px; padding: 8px 15px; background: #28a745; color: white; text-decoration: none; border-radius: 4px;">View Today</a>
        </div>
        
        <div style="border: 1px solid #ddd; padding: 20px; border-radius: 5px; width: 250px; text-align: center;">
            <h2>⚙️</h2>
            <h3>My Schedule</h3>
            <p>Manage your working hours</p>
            <a asp-action="Schedule" style="display: inline-block; margin-top: 10px; padding: 8px 15px; background: #17a2b8; color: white; text-decoration: none; border-radius: 4px;">Manage Schedule</a>
        </div>
    </div>
</div>
