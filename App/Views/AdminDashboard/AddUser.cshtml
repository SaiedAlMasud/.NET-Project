@model App.Models.RegisterViewModel

@{
    ViewData["Title"] = "Add New User";
    Layout = "_Layout";
    var role = ViewBag.Role as string ?? "Patient";
}

<div style="padding: 20px; max-width: 600px; margin: 0 auto;">
    <h1>Add New User</h1>
    
    @if (TempData["Error"] != null)
    {
        <div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
            @TempData["Error"]
        </div>
    }
    
    <hr />
    
    <div>
        <label>Register as:</label>
        <select onchange="window.location.href='/Account/Register?role='+this.value" style="margin-left: 10px; padding: 5px;">
            <option value="Patient" selected="@(role == "Patient" ? "selected" : null)">Patient</option>
            <option value="Doctor" selected="@(role == "Doctor" ? "selected" : null)">Doctor</option>
            <option value="Admin" selected="@(role == "Admin" ? "selected" : null)">Admin</option>
        </select>
    </div>

    <form asp-action="AddUser" method="post">
        <input type="hidden" name="Role" value="@role" />
        
        <!-- FIRST NAME -->
        <div style="margin-bottom: 10px; margin-top: 15px;">
            <label asp-for="FirstName"></label><br />
            <input asp-for="FirstName" style="width:300px;" />
            <span asp-validation-for="FirstName" style="color:red;"></span>
        </div>

        <!-- LAST NAME -->
        <div style="margin-bottom: 10px;">
            <label asp-for="LastName"></label><br />
            <input asp-for="LastName" style="width:300px;" />
            <span asp-validation-for="LastName" style="color:red;"></span>
        </div>

        <!-- EMAIL -->
        <div style="margin-bottom: 10px;">
            <label asp-for="Email"></label><br />
            <input asp-for="Email" type="email" style="width:300px;" />
            <span asp-validation-for="Email" style="color:red;"></span>
        </div>

        <!-- PHONE -->
        <div style="margin-bottom: 10px;">
            <label asp-for="PhoneNumber"></label><br />
            <input asp-for="PhoneNumber" style="width:300px;" />
            <span asp-validation-for="PhoneNumber" style="color:red;"></span>
        </div>

        <!-- DOB -->
        <div style="margin-bottom: 10px;">
            <label asp-for="DateOfBirth"></label><br />
            <input asp-for="DateOfBirth" type="date" style="width:300px;" />
            <span asp-validation-for="DateOfBirth" style="color:red;"></span>
        </div>

        <!-- GENDER -->
        <div style="margin-bottom: 10px;">
            <label asp-for="Gender"></label><br />
            <select asp-for="Gender" style="width:300px;">
                <option value="">Select Gender</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
            </select>
            <span asp-validation-for="Gender" style="color:red;"></span>
        </div>

        <!-- DOCTOR FIELDS -->
        @if (role == "Doctor")
        {
            <div style="margin-top:15px; border:1px solid #ddd; padding:10px;">
                <div style="margin-bottom: 10px;">
                    <label asp-for="Specialization"></label><br />
                    <input asp-for="Specialization" style="width:300px;" />
                    <span asp-validation-for="Specialization" style="color:red;"></span>
                </div>

                <div style="margin-bottom: 10px;">
                    <label asp-for="ConsultationFee"></label><br />
                    <input asp-for="ConsultationFee" type="number" step="0.01" style="width:300px;" />
                    <span asp-validation-for="ConsultationFee" style="color:red;"></span>
                </div>
            </div>
        }

        <!-- PASSWORD -->
        <div style="margin-bottom: 10px;">
            <label asp-for="Password"></label><br />
            <input asp-for="Password" type="password" style="width:300px;" />
            <span asp-validation-for="Password" style="color:red;"></span>
        </div>

        <!-- CONFIRM PASSWORD -->
        <div style="margin-bottom: 10px;">
            <label asp-for="ConfirmPassword"></label><br />
            <input asp-for="ConfirmPassword" type="password" style="width:300px;" />
            <span asp-validation-for="ConfirmPassword" style="color:red;"></span>
        </div>

        <button type="submit" style="padding:5px 15px;">Add User</button>
        <a asp-action="Users" style="margin-left: 10px; padding: 5px 15px; background: #6c757d; color: white; text-decoration: none; border-radius: 4px;">Cancel</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}