@model IEnumerable<BLL.DTOs.UserDTO>

@{
    ViewData["Title"] = "Manage Users";
    Layout = "_Layout";
}

<div style="padding: 20px;">
    <h1>Manage Users</h1>
    
    @if (TempData["Success"] != null)
    {
        <div style="background: #d4edda; color: #155724; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
            @TempData["Success"]
        </div>
    }
    
    @if (TempData["Error"] != null)
    {
        <div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
            @TempData["Error"]
        </div>
    }
    
    <hr />
    
    <div style="margin-bottom: 20px;">
        <a asp-action="AddUser" style="display: inline-block; padding: 8px 15px; background: #28a745; color: white; text-decoration: none; border-radius: 4px;">+ Add New User</a>
    </div>
    
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: #f2f2f2;">
                <th style="border: 1px solid #ddd; padding: 10px; text-align: left;">ID</th>
                <th style="border: 1px solid #ddd; padding: 10px; text-align: left;">Email</th>
                <th style="border: 1px solid #ddd; padding: 10px; text-align: left;">Role</th>
                <th style="border: 1px solid #ddd; padding: 10px; text-align: left;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="border: 1px solid #ddd; padding: 10px;">@item.Id</td>
                    <td style="border: 1px solid #ddd; padding: 10px;">@item.Email</td>
                    <td style="border: 1px solid #ddd; padding: 10px;">
                        @if (item.Role == "Admin")
                        {
                            <span style="background: #dc3545; color: white; padding: 3px 8px; border-radius: 3px;">@item.Role</span>
                        }
                        else if (item.Role == "Doctor")
                        {
                            <span style="background: #28a745; color: white; padding: 3px 8px; border-radius: 3px;">@item.Role</span>
                        }
                        else
                        {
                            <span style="background: #007bff; color: white; padding: 3px 8px; border-radius: 3px;">@item.Role</span>
                        }
                    </td>
                    <td style="border: 1px solid #ddd; padding: 10px;">
                        <a asp-action="UserDetails" asp-route-id="@item.Id" style="color: blue; margin-right: 10px;">View</a>
                        <a asp-action="ResetPassword" asp-route-id="@item.Id" style="color: orange; margin-right: 10px;">Reset Password</a>
                        <a asp-action="DeleteUser" asp-route-id="@item.Id" onclick="return confirm('Are you sure?')" style="color: red;">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
    <div style="margin-top: 20px;">
        <a asp-action="Index" style="display: inline-block; padding: 8px 15px; background: #6c757d; color: white; text-decoration: none; border-radius: 4px;">Back to Dashboard</a>
    </div>
</div>